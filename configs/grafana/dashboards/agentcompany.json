{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "AgentCompany — HTTP, agent lifecycle, LLM cost, adapter health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_http_requests_total[5m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "histogram_quantile(0.50, sum(rate(agentcompany_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "histogram_quantile(0.99, sum(rate(agentcompany_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "B"
        }
      ],
      "title": "Request Latency p50 / p99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(agentcompany_http_requests_total[5m]))",
          "legendFormat": "5xx error rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_http_requests_total{status=~\"4..\"}[5m])) / sum(rate(agentcompany_http_requests_total[5m]))",
          "legendFormat": "4xx error rate",
          "refId": "B"
        }
      ],
      "title": "HTTP Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Agents",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 45 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 18 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(agentcompany_active_agents)",
          "legendFormat": "Active agents",
          "refId": "A"
        }
      ],
      "title": "Active Agents",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 18 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_agent_runs_total{status=\"success\"}[5m])) by (role)",
          "legendFormat": "success {{role}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_agent_runs_total{status=\"error\"}[5m])) by (role)",
          "legendFormat": "error {{role}}",
          "refId": "B"
        }
      ],
      "title": "Agent Run Rate by Role",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "LLM Usage & Cost",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_llm_tokens_total{direction=\"prompt\"}[5m])) by (provider)",
          "legendFormat": "prompt {{provider}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_llm_tokens_total{direction=\"completion\"}[5m])) by (provider)",
          "legendFormat": "completion {{provider}}",
          "refId": "B"
        }
      ],
      "title": "LLM Token Rate (tokens/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_llm_cost_usd_total[1h])) by (provider) * 3600",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "title": "LLM Cost Rate (USD/hour)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 22,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "histogram_quantile(0.50, sum(rate(agentcompany_llm_call_duration_seconds_bucket[5m])) by (le, provider, model))",
          "legendFormat": "p50 {{provider}}/{{model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "histogram_quantile(0.99, sum(rate(agentcompany_llm_call_duration_seconds_bucket[5m])) by (le, provider, model))",
          "legendFormat": "p99 {{provider}}/{{model}}",
          "refId": "B"
        }
      ],
      "title": "LLM Call Latency p50 / p99",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 103,
      "title": "Tool / Adapter Calls",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_tool_calls_total{status=\"success\"}[5m])) by (adapter)",
          "legendFormat": "success {{adapter}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "sum(rate(agentcompany_tool_calls_total{status=\"error\"}[5m])) by (adapter)",
          "legendFormat": "error {{adapter}}",
          "refId": "B"
        }
      ],
      "title": "Tool Call Rate (success vs error)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "id": 31,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-agentcompany" },
          "expr": "agentcompany_adapter_healthy",
          "legendFormat": "{{adapter}}",
          "refId": "A"
        }
      ],
      "title": "Adapter Health (1=healthy)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["agentcompany", "runtime"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AgentCompany Runtime",
  "uid": "agentcompany-runtime",
  "version": 1
}
