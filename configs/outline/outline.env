# Outline configuration for AgentCompany
#
# This file is sourced by Outline inside the container.  It is NOT the same as
# the root .env file — Docker Compose injects these values directly via the
# `environment:` block.  This file exists as a reference / documentation
# source for every Outline-specific setting so operators know what is
# configurable without digging through Outline's upstream docs.
#
# Values that reference shell variables (${...}) are resolved at container
# startup time by Docker Compose; the actual secrets live in the root .env.

# ---------------------------------------------------------------------------
# Cryptographic secrets
# ---------------------------------------------------------------------------

# Randomly generated 32-byte hex string.  Must never change after first run —
# rotating this key invalidates all existing user sessions and signed URLs.
SECRET_KEY=${OUTLINE_SECRET_KEY}

# Secondary secret used for HMAC signing of utility tokens (e.g. export URLs).
# Can be rotated independently of SECRET_KEY.
UTILS_SECRET=${OUTLINE_UTILS_SECRET}

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Shared Postgres instance; each service owns its own database.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/outline

# Connection pool settings for production.  The defaults work fine for
# small teams; increase pool_max for 50+ concurrent users.
DATABASE_CONNECTION_POOL_MIN=1
DATABASE_CONNECTION_POOL_MAX=5

# ---------------------------------------------------------------------------
# Redis — used for session caching, pub/sub for collaborative editing,
# and background job queues.
# ---------------------------------------------------------------------------

REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ---------------------------------------------------------------------------
# Application URL
# ---------------------------------------------------------------------------

# The externally-accessible URL that browsers use to reach Outline.
# Must match the redirect URI registered in Keycloak.
URL=${OUTLINE_URL:-http://localhost/docs}

PORT=3000

# ---------------------------------------------------------------------------
# Authentication — OIDC via Keycloak
# ---------------------------------------------------------------------------

# The client ID registered in the agentcompany Keycloak realm.
OIDC_CLIENT_ID=${OUTLINE_OIDC_CLIENT_ID:-outline}

# Client secret from Keycloak — must match the value in realm-export.json.
OIDC_CLIENT_SECRET=${OUTLINE_OIDC_CLIENT_SECRET}

# Auth endpoint: must be the publicly-reachable Keycloak URL (browser redirect).
OIDC_AUTH_URI=${KEYCLOAK_HOSTNAME:-http://localhost}/auth/realms/${KEYCLOAK_REALM:-agentcompany}/protocol/openid-connect/auth

# Token + userinfo endpoints: use the internal Docker hostname because these
# calls happen server-side (container → container), never from the browser.
OIDC_TOKEN_URI=http://keycloak:8080/auth/realms/${KEYCLOAK_REALM:-agentcompany}/protocol/openid-connect/token
OIDC_USERINFO_URI=http://keycloak:8080/auth/realms/${KEYCLOAK_REALM:-agentcompany}/protocol/openid-connect/userinfo

# Claim in the ID token to use as the Outline username.
OIDC_USERNAME_CLAIM=preferred_username

# Display name shown on the Outline login page for this provider.
OIDC_DISPLAY_NAME=AgentCompany SSO

# Scopes to request.  email is required; profile populates display name.
OIDC_SCOPES=openid profile email

# ---------------------------------------------------------------------------
# File storage — MinIO as S3-compatible backend
# ---------------------------------------------------------------------------

FILE_STORAGE=s3

# MinIO credentials — use the same root user that the minio-init container
# uses to create buckets.  In production, create a dedicated IAM user with
# write access to only the outline bucket.
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER:-agentcompany}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# Any non-empty string; MinIO does not enforce AWS regions.
AWS_REGION=us-east-1

# Internal MinIO endpoint.  Outline uses this for both upload presign
# and direct upload, so it must be reachable from inside the container.
AWS_S3_UPLOAD_BUCKET_URL=http://minio:9000

# Name of the bucket created by minio-init.
AWS_S3_UPLOAD_BUCKET_NAME=${OUTLINE_S3_BUCKET:-outline}

# Path-style is required for MinIO (vs. virtual-hosted-style used by AWS S3).
AWS_S3_FORCE_PATH_STYLE=true

# private: Outline generates signed URLs for downloads.
# Do not set to public — that would let anyone with the URL skip auth.
AWS_S3_ACL=private

# ---------------------------------------------------------------------------
# SMTP (optional) — leave blank to disable email; Outline will still work
# but cannot send invites, password resets, or document-share emails.
# ---------------------------------------------------------------------------

SMTP_HOST=${SMTP_HOST:-}
SMTP_PORT=${SMTP_PORT:-587}
SMTP_USERNAME=${SMTP_USERNAME:-}
SMTP_PASSWORD=${SMTP_PASSWORD:-}
SMTP_FROM_EMAIL=${SMTP_FROM_EMAIL:-noreply@agentcompany.local}
SMTP_REPLY_EMAIL=${SMTP_FROM_EMAIL:-noreply@agentcompany.local}
SMTP_TLS_CIPHERS=

# ---------------------------------------------------------------------------
# Security and misc
# ---------------------------------------------------------------------------

# false: allows plain HTTP.  Set to true (and configure a valid TLS cert)
# before accepting real user traffic.
FORCE_HTTPS=false

# Disable the "Updates available" banner to avoid confusion in dev.
ENABLE_UPDATES=false

LOG_LEVEL=info

# Maximum file upload size in bytes (default 10 MB).  Increase if your team
# uploads large files.
FILE_STORAGE_UPLOAD_MAX_SIZE=10485760

# Collaboration engine.  Enabled by default; disable only if debugging
# concurrent-edit issues.
COLLABORATION_URL=
