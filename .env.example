# AgentCompany — environment variables
#
# Copy this file to .env before running docker-compose:
#   cp .env.example .env
#
# All CHANGE_ME values MUST be replaced with strong random secrets.
# Use `scripts/setup.sh` which auto-generates secrets, or run:
#   openssl rand -hex 32
#
# Variables marked "optional" can be left blank; the platform will
# start without them but the related feature will be disabled.

###############################################################################
# TRAEFIK
###############################################################################

# Host port Traefik listens on for HTTP traffic
TRAEFIK_HTTP_PORT=80

# Host port Traefik listens on for HTTPS traffic
TRAEFIK_HTTPS_PORT=443

# Host port for the Traefik dashboard (development only — restrict in prod)
TRAEFIK_DASHBOARD_PORT=8080

###############################################################################
# POSTGRESQL (shared instance)
###############################################################################

# Superuser that owns all application databases
POSTGRES_USER=agentcompany

# Strong random password — CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

###############################################################################
# REDIS (shared instance)
###############################################################################

# Strong random password — CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# Maximum memory Redis may consume before evicting keys
REDIS_MAX_MEMORY=256mb

###############################################################################
# MINIO — S3-compatible object storage
###############################################################################

# Root credentials (equivalent to AWS access key/secret)
MINIO_ROOT_USER=agentcompany
MINIO_ROOT_PASSWORD=CHANGE_ME

# Public URL for the MinIO browser console (used in CORS headers)
MINIO_BROWSER_REDIRECT_URL=http://localhost/minio-console

# Bucket name for Outline attachments
OUTLINE_S3_BUCKET=outline

###############################################################################
# KEYCLOAK — Identity / SSO
###############################################################################

# Externally reachable base URL (no trailing slash)
KEYCLOAK_HOSTNAME=http://localhost

# Realm name — create this realm in the Keycloak admin after first boot
KEYCLOAK_REALM=agentcompany

# Bootstrap admin credentials (change after first login)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

###############################################################################
# OUTLINE — Documentation wiki
###############################################################################

# Publicly reachable URL for this Outline instance
OUTLINE_URL=http://localhost/docs

# 32-byte hex secret for session signing — CHANGE_ME
OUTLINE_SECRET_KEY=CHANGE_ME

# 32-byte hex utility secret — CHANGE_ME
OUTLINE_UTILS_SECRET=CHANGE_ME

# OIDC application registered in the Keycloak agentcompany realm
OUTLINE_OIDC_CLIENT_ID=outline
OUTLINE_OIDC_CLIENT_SECRET=CHANGE_ME

###############################################################################
# MATTERMOST — Team chat
###############################################################################

# Site URL used in notification emails and deep-links
MATTERMOST_SITE_URL=http://localhost/chat

###############################################################################
# MEILISEARCH — Full-text search engine
###############################################################################

# Master key (min 16 chars) — CHANGE_ME
MEILISEARCH_MASTER_KEY=CHANGE_ME

# "development" exposes the search preview UI; use "production" otherwise
MEILISEARCH_ENV=development

###############################################################################
# AGENT RUNTIME — Custom FastAPI service
###############################################################################

# 32-byte hex secret for JWT signing — CHANGE_ME
AGENT_RUNTIME_SECRET_KEY=CHANGE_ME

# OIDC client registered in Keycloak for machine-to-machine auth
AGENT_RUNTIME_KEYCLOAK_CLIENT_ID=agentcompany-api
AGENT_RUNTIME_KEYCLOAK_CLIENT_SECRET=CHANGE_ME

###############################################################################
# WEB UI — Custom Next.js application
###############################################################################

# Where the browser will call the Agent Runtime API
WEB_UI_API_URL=http://localhost/api

# OIDC public client registered in Keycloak (no secret needed for public clients)
WEB_UI_KEYCLOAK_CLIENT_ID=agentcompany-web

###############################################################################
# APPLICATION (global)
###############################################################################

# "development" | "production"
APP_ENV=development

# "debug" | "info" | "warning" | "error"
LOG_LEVEL=info

###############################################################################
# OLLAMA — Local LLM inference
###############################################################################

# Host port exposed by the Ollama container
OLLAMA_PORT=11434

# URL the agent-runtime uses to reach Ollama inside the Docker network
OLLAMA_BASE_URL=http://ollama:11434

# Default model served to agents (pulled by scripts/ollama-setup.sh on first boot)
OLLAMA_MODEL=gemma3

# Set to "true" when running on a host with an NVIDIA GPU.
# When "false" (default), use docker-compose.override.yml to strip the GPU
# reservation from the Ollama service definition.
OLLAMA_GPU_ENABLED=false

###############################################################################
# SMTP — email delivery (optional)
###############################################################################

# Leave blank to disable outbound email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@agentcompany.local
