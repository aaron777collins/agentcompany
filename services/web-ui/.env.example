# AgentCompany Web UI — Environment Variables
# Copy this file to .env.local and fill in real values before running.

# Core API base URL — all REST calls go here
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Keycloak OIDC — required for authenticated deployments.
# When these are set, the UI initiates a PKCE authorization code flow and
# attaches a Bearer token to every API request.
# Leave unset (or blank) in bare local dev to skip auth entirely (dev mode).
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8180
NEXT_PUBLIC_KEYCLOAK_REALM=agentcompany
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=web-ui

# Feature flags — set to "true" to enable experimental features
NEXT_PUBLIC_ENABLE_DRAG_DROP=false
NEXT_PUBLIC_ENABLE_ORG_CHART_EDIT=false

# Runtime environment — controls error verbosity in UI
NODE_ENV=development
